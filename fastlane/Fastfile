require "json"
require "shellwords"

default_platform(:ios)

platform :ios do
  desc "Build iOS app"
  lane :build do |options|
    # 必須オプションの確認
    scheme = options[:scheme]
    if scheme.nil? || scheme.strip.empty?
      UI.user_error!("scheme option is required")
    end

    source_root_input = options[:source_root]
    if source_root_input.nil? || source_root_input.strip.empty?
      UI.user_error!("source_root option is required")
    end

    # .xcworkspace へのパスを解決
    workspace = resolve_workspace_path(source_root: source_root_input)

    scan(
      workspace: workspace,
      scheme: scheme,
      configuration: "Debug",
      clean: true,
      build_for_testing: true,
      output_types: ""
    )
  end

  desc "Run unit tests for iOS app"
  lane :unit_test do |options|
    # 必須オプションの確認
    source_root_input = options[:source_root]
    if source_root_input.nil? || source_root_input.strip.empty?
      UI.user_error!("source_root option is required")
    end

    # .xcworkspace へのパスを解決
    workspace = resolve_workspace_path(source_root: source_root_input)
    # テスト対象 Scheme を検索
    test_schemes = resolve_test_schemes(workspace: workspace)

    # テスト対象 Scheme が存在しなかった場合はスキップする
    if test_schemes.empty?
      UI.important("No test schemes matching '*Tests' were found in workspace '#{workspace}', skipping unit tests.")
      next
    end

    UI.message("Running unit tests for schemes: #{test_schemes.join(', ')}")

    test_schemes.each do |test_scheme|
      scan(
        workspace: workspace,
        scheme: test_scheme,
        devices: ["iPhone 17"],
        configuration: "Debug",
        clean: true,
        output_types: "html"
      )
    end
  end

  desc "Resolve the path to the .xcworkspace file under the given source root"
  private_lane :resolve_workspace_path do |options|
    source_root_input = options[:source_root]
    if source_root_input.nil? || source_root_input.strip.empty?
      UI.user_error!("source_root option is required")
    end

    source_roots = if source_root_input.start_with?("/")
      [source_root_input]
    else
      [
        File.expand_path(source_root_input, Dir.pwd),
        File.expand_path("../#{source_root_input}", __dir__)
      ]
    end
    source_roots = source_roots.uniq.select { |path| Dir.exist?(path) }

    if source_roots.empty?
      UI.user_error!("source_root '#{source_root_input}' does not exist")
    end

    workspace = source_roots
      .flat_map { |root| Dir.glob(File.join(root, "**/*.xcworkspace")) }
      .sort
      .first

    if workspace.nil?
      UI.user_error!("No .xcworkspace found under source_root '#{source_root_input}'")
    end

    workspace
  end

  desc "Resolve schemes named '*Tests' in the given workspace"
  private_lane :resolve_test_schemes do |options|
    workspace = options[:workspace]
    if workspace.nil? || workspace.strip.empty?
      UI.user_error!("workspace option is required")
    end

    workspace_info_output = sh(
      "xcodebuild -workspace #{Shellwords.escape(workspace)} -list -json",
      log: false
    )

    json_start = workspace_info_output.index("{")
    json_end = workspace_info_output.rindex("}")
    if json_start.nil? || json_end.nil? || json_end < json_start
      UI.user_error!("Failed to extract JSON from xcodebuild output")
    end

    workspace_info_json = workspace_info_output[json_start..json_end]
    begin
      workspace_info = JSON.parse(workspace_info_json)
    rescue JSON::ParserError => e
      UI.user_error!("Failed to parse xcodebuild JSON output: #{e.message}")
    end

    all_schemes = Array(workspace_info.dig("workspace", "schemes")) + Array(workspace_info.dig("project", "schemes"))
    Array(all_schemes).uniq.select { |scheme| scheme.end_with?("Tests") }
  end
end
